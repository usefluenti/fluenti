{
  "name": "@fluenti/solid",
  "version": "0.1.3",
  "type": "module",
  "description": "SolidJS compile-time i18n — Trans/Plural/Select components, I18nProvider, useI18n",
  "homepage": "https://fluenti.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usefluenti/fluenti.git",
    "directory": "packages/solid"
  },
  "bugs": {
    "url": "https://github.com/usefluenti/fluenti/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["i18n", "internationalization", "compile-time", "icu", "messageformat", "solid", "solidjs", "signals"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "solid": {
        "types": "./dist/index.d.ts",
        "default": "./src/index.ts"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite-plugin": {
      "import": { "types": "./dist/vite-plugin.d.ts", "default": "./dist/vite-plugin.js" },
      "require": { "types": "./dist/vite-plugin.d.ts", "default": "./dist/vite-plugin.cjs" }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "solid-js": "^1.8",
    "vite": "^5 || ^6 || ^8"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true }
  },
  "dependencies": {
    "@fluenti/core": "workspace:*",
    "@fluenti/vite-plugin": "workspace:*"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8",
    "@vitest/coverage-v8": "^4",
    "happy-dom": "^20",
    "solid-js": "^1.9",
    "typescript": "^5.9",
    "vite": "^8",
    "vite-plugin-dts": "^4",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4"
  }
}
