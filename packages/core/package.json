{
  "name": "@fluenti/core",
  "version": "0.0.0",
  "type": "module",
  "description": "Framework-agnostic compile-time i18n core — ICU parser, compiler, interpolation, formatters",
  "homepage": "https://fluenti.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usefluenti/fluenti.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/usefluenti/fluenti/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["i18n", "internationalization", "compile-time", "icu", "messageformat", "plural", "select", "ssr", "formatters"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.ts", "default": "./dist/index.cjs" }
    },
    "./internal": {
      "import": { "types": "./dist/internal.d.ts", "default": "./dist/internal.js" },
      "require": { "types": "./dist/internal.d.ts", "default": "./dist/internal.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "bench": "vitest bench"
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.28.4"
  },
  "devDependencies": {
    "typescript": "^5.9",
    "vite": "^8",
    "vite-plugin-dts": "^4",
    "vitest": "^4",
    "@vitest/coverage-v8": "^4"
  }
}
