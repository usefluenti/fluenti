{
  "name": "@fluenti/core",
  "version": "0.0.1",
  "type": "module",
  "description": "Framework-agnostic compile-time i18n core — ICU parser, compiler, interpolation, formatters",
  "homepage": "https://fluenti.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usefluenti/fluenti.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/usefluenti/fluenti/issues"
  },
  "license": "MIT",
  "keywords": ["i18n", "internationalization", "compile-time", "icu", "messageformat", "plural", "select", "ssr", "formatters"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9",
    "vitest": "^4",
    "tsup": "^8",
    "@vitest/coverage-v8": "^4"
  }
}
