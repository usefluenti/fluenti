{
  "name": "@fluenti/next",
  "version": "0.0.1",
  "description": "Fluenti integration for Next.js — compile-time i18n transforms and auto-compilation",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./loader": {
      "import": {
        "types": "./dist/loader.d.ts",
        "default": "./dist/loader.js"
      },
      "require": {
        "types": "./dist/loader.d.cts",
        "default": "./dist/loader.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "dependencies": {
    "@fluenti/core": "workspace:*",
    "@fluenti/react": "workspace:*"
  },
  "devDependencies": {
    "next": "^15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/node": "^22",
    "typescript": "^5.9",
    "vitest": "^4",
    "tsup": "^8"
  },
  "keywords": ["i18n", "fluenti", "next.js", "webpack", "turbopack"],
  "license": "MIT"
}
