{
  "name": "@fluenti/vite-plugin",
  "version": "0.1.3",
  "type": "module",
  "description": "Vite plugin for Fluenti — build-time transforms, virtual modules, code splitting",
  "homepage": "https://fluenti.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usefluenti/fluenti.git",
    "directory": "packages/vite-plugin"
  },
  "bugs": {
    "url": "https://github.com/usefluenti/fluenti/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "compile-time",
    "icu",
    "messageformat",
    "vite",
    "vite-plugin",
    "build-time",
    "code-splitting"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./sfc-transform": {
      "import": {
        "types": "./dist/sfc-transform.d.ts",
        "default": "./dist/sfc-transform.js"
      },
      "require": {
        "types": "./dist/sfc-transform.d.ts",
        "default": "./dist/sfc-transform.cjs"
      }
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "files": [
    "dist",
    "client.d.ts"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fluenti/core": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4",
    "@vue/compiler-sfc": "^3.5",
    "typescript": "^5.9",
    "vite": "^8",
    "vite-plugin-dts": "^4",
    "vitest": "^4"
  }
}
