{
  "name": "@fluenti/next",
  "version": "0.1.2",
  "type": "module",
  "description": "Next.js plugin for Fluenti — withFluenti, FluentProvider, t`` transforms for App Router and Pages Router",
  "homepage": "https://fluenti.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usefluenti/fluenti.git",
    "directory": "packages/next-plugin"
  },
  "bugs": {
    "url": "https://github.com/usefluenti/fluenti/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "compile-time",
    "icu",
    "messageformat",
    "next",
    "nextjs",
    "rsc",
    "server-components"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.cjs"
      }
    },
    "./provider": {
      "import": {
        "types": "./dist/provider.d.ts",
        "default": "./dist/provider.js"
      },
      "require": {
        "types": "./dist/provider.d.ts",
        "default": "./dist/provider.cjs"
      }
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "files": [
    "dist",
    "client.d.ts"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@fluenti/core": "workspace:*",
    "@fluenti/react": "workspace:*",
    "jiti": "^2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4",
    "next": "^15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9",
    "vite": "^8",
    "vite-plugin-dts": "^4",
    "vitest": "^4",
    "webpack": "^5"
  }
}
