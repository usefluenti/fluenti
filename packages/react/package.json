{
  "name": "@fluenti/react",
  "version": "0.1.0",
  "type": "module",
  "description": "React bindings for Fluenti — I18nProvider, useI18n, Trans/Plural/Select components",
  "homepage": "https://fluenti.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usefluenti/fluenti.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/usefluenti/fluenti/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["i18n", "internationalization", "compile-time", "icu", "messageformat", "react", "hooks", "provider"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.ts", "default": "./dist/index.cjs" }
    },
    "./server": {
      "import": { "types": "./dist/server.d.ts", "default": "./dist/server.js" },
      "require": { "types": "./dist/server.d.ts", "default": "./dist/server.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@fluenti/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9",
    "vite": "^8",
    "vite-plugin-dts": "^4",
    "vitest": "^4",
    "@vitest/coverage-v8": "^4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20"
  }
}
