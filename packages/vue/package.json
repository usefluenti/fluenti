{
  "name": "@fluenti/vue",
  "version": "0.2.1",
  "type": "module",
  "description": "Vue 3 compile-time i18n — v-t directive, Trans/Plural/Select components, useI18n composable",
  "homepage": "https://fluenti.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usefluenti/fluenti.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/usefluenti/fluenti/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["i18n", "internationalization", "compile-time", "icu", "messageformat", "vue", "vue3", "directive", "composable"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.ts", "default": "./dist/index.cjs" }
    },
    "./vite-plugin": {
      "import": { "types": "./dist/vite-plugin.d.ts", "default": "./dist/vite-plugin.js" },
      "require": { "types": "./dist/vite-plugin.d.ts", "default": "./dist/vite-plugin.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5",
    "vite": "^5 || ^6 || ^8"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true }
  },
  "dependencies": {
    "@fluenti/core": "workspace:*",
    "@fluenti/vite-plugin": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9",
    "vite": "^8",
    "vite-plugin-dts": "^4",
    "vitest": "^4",
    "@vitest/coverage-v8": "^4",
    "vue": "^3.5",
    "@vue/test-utils": "^2",
    "happy-dom": "^20"
  }
}
