{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vinxi/types/client", "@fluenti/vite-plugin/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "app.config.ts"]
}
